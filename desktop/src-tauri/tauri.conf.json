{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Herd Studio Desktop",
  "version": "0.1.0",
  "identifier": "com.kylemcgowan.herdstudio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4174"
  },
  "app": {
    "windows": [
      {
        "title": "Herd Studio Desktop",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
